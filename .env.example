# Copy to .env (auto-loaded). All optional -- the agent runs LLM-free without a key.

# Anthropic key -> enables LLM planner, distiller/QA narrative, and the vision read.
ANTHROPIC_API_KEY=

# Models routed through the gateway
LLM_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6

# Browser: set HEADLESS=0 (+ SLOW_MO) to record the visible demo
HEADLESS=1
SLOW_MO=0

# Task knobs (defaults target the HF text-generation-by-likes demo)
TOP_N=3
TASK_FILTER=text-generation
TASK_FILTER_LABEL=Text Generation
SORT_BY=likes
SORT_LABEL=Most likes
TARGET_URL=https://huggingface.co/models

# Force the (labelled) vision set-of-marks read on model #1 when a key is present
FORCE_VISION_DEMO=1
